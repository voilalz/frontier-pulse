# Optional. Without this key, the daily workflow uses deterministic ranking
# and evidence-preserving summaries derived from RSS metadata.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional administrator-managed email digest. Store real values in GitHub
# Actions Secrets/Variables, never in a committed .env file.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
EMAIL_FROM=
EMAIL_TO=
EMAIL_REPLY_TO=
SITE_URL=https://frontier-pulse.jiumi674.workers.dev

# Only needed for optional Wrangler Direct Upload. Prefer GitHub Secrets.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
