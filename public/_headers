/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' https: data:; connect-src 'self'; worker-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests

/data/news.json
  Cache-Control: public, max-age=300, must-revalidate

/data/status.json
  Cache-Control: public, max-age=60, must-revalidate

/data/stream.json
  Cache-Control: public, max-age=300, must-revalidate

/data/stream-status.json
  Cache-Control: public, max-age=60, must-revalidate

/data/research.json
  Cache-Control: public, max-age=1800, must-revalidate

/data/archive/*
  Cache-Control: public, max-age=300, must-revalidate

/feed.xml
  Cache-Control: public, max-age=300, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/og-card.png
  Cache-Control: public, max-age=86400, must-revalidate

/assets/*
  Cache-Control: public, max-age=3600, must-revalidate
